rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'icon']) &&
             data.keys().size() <= 2 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.icon is string && data.icon.size() > 0 && data.icon.size() <= 100;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'image', 'categoryId']) &&
             data.keys().size() <= 7 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 150 &&
             data.description is string && data.description.size() <= 1000 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 2000 &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             (data.get('hasStock', false) is bool) &&
             (data.get('stockCount', 0) is number);
    }

    function isValidSection(data) {
      return data.keys().hasAll(['name']) &&
             data.keys().size() <= 1 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    function isValidTable(data) {
      return data.keys().hasAll(['name', 'sectionId']) &&
             data.keys().size() <= 2 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.sectionId is string && data.sectionId.size() <= 128;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'totalAmount', 'tableId', 'updatedAt']) &&
             data.keys().size() <= 4 &&
             data.items is string && data.items.size() <= 1000000 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.tableId is string && data.tableId.size() <= 128 &&
             data.updatedAt is number;
    }

    function isValidSetting(data) {
      return data.keys().size() <= 12 &&
             data.get('name', 'Unknown') is string &&
             data.get('description', '') is string &&
             data.get('logo', '') is string &&
             data.get('coverImage', '') is string &&
             data.get('instagram', '') is string &&
             data.get('twitter', '') is string &&
             data.get('facebook', '') is string &&
             data.get('tiktok', '') is string &&
             data.get('wifiSsid', '') is string &&
             data.get('wifiPassword', '') is string;
    }

    function isValidSale(data) {
         return data.keys().hasAll(['tableId', 'items', 'totalAmount', 'paymentMethod', 'createdAt']) &&
                data.keys().size() <= 5 &&
                data.tableId is string && data.tableId.size() <= 128 &&
                data.items is string && data.items.size() <= 1000000 &&
                data.totalAmount is number && data.totalAmount >= 0 &&
                data.paymentMethod is string && data.paymentMethod.size() <= 50 &&
                data.createdAt is number;
    }

    function isValidAppUser(data) {
        return data.keys().hasAll(['name', 'pin', 'role']) &&
               data.keys().size() <= 3 &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.pin is string && data.pin.size() <= 10 &&
               data.role is string && (data.role == 'admin' || data.role == 'waiter');
    }

    match /firms/{firmId} {
      // Anyone can read a firm to authenticate, but we shouldn't necessarily allow listing all firms without filtering,
      // but for this prototype, allow read and list for signed-in users (including anonymous for POS).
      // A better secure check would be to only allow read if the credentials match or if it's the admin.
      allow read, list: if true;
      allow create, update, delete: if isSignedIn(); // For SuperAdmin

      match /settings/{settingId} {
        allow read: if true;
        allow write: if isSignedIn() && isValidId(settingId) && isValidSetting(incoming());
      }

      match /sales/{saleId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(saleId) && isValidSale(incoming());
        allow update: if isSignedIn() && isValidSale(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['tableId', 'items', 'totalAmount', 'paymentMethod', 'createdAt']);
        allow delete: if isSignedIn();
      }

      match /appusers/{userId} {
        allow read, write: if true;
      }

      match /categories/{categoryId} {
        allow read, list: if true;
        allow create: if isSignedIn() && isValidId(categoryId) && isValidCategory(incoming());
        allow update: if isSignedIn() && isValidCategory(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'icon']);
        allow delete: if isSignedIn();
      }

      match /products/{productId} {
        allow read, list: if true;
        allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
        allow update: if isSignedIn() && isValidProduct(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'image', 'categoryId', 'hasStock', 'stockCount']);
        allow delete: if isSignedIn();
      }

      match /sections/{sectionId} {
        allow read, list: if true;
        allow create: if isSignedIn() && isValidId(sectionId) && isValidSection(incoming());
        allow update: if isSignedIn() && isValidSection(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name']);
        allow delete: if isSignedIn();
      }

      match /tables/{tableId} {
        allow read, list: if true;
        allow create: if isSignedIn() && isValidId(tableId) && isValidTable(incoming());
        allow update: if isSignedIn() && isValidTable(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'sectionId']);
        allow delete: if isSignedIn();
      }

      match /orders/{orderId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming());
        allow update: if isSignedIn() && isValidOrder(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['items', 'totalAmount', 'tableId', 'updatedAt']);
        allow delete: if isSignedIn();
      }
    }
  }
}
